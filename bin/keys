#!/usr/bin/env bash

usage() {
    echo
    show bold "Generate an age public key pair and backup documentation."
    echo
    show "Usage:" bold blue "valt keys" "[OPTIONS]"
    echo
    show "Private keys are encrypted and a strong passphrase is" bold green "highly" "encouraged; advice and an opportunity to"
    echo "generate one will be offered."
    echo
    echo "A PDF file will be created containing your keys, also in encrypted form, to serve as a backup for you and/or your"
    echo "successors. Detailed usage instructions are included. Keys are represented as a QR code and again in a text format"
    show "(often called \"paper keys\"). Content is personalized so you will be prompted to edit a" blue "key.info" "file."
    echo
    show "Please ensure that you print at least one copy of the PDF file" bold "and" italic "write your passphrase" "on the last page (or"
    echo "leave the passphrase blank and add instructions on where to find in the Notes section)."
    echo
    show "  " bold "store the document in secure locations, e.g. safe deposit box/fire safe and/or with trusted people!"
    echo
    echo "Options"
    echo
    echo "    -n, --name NAME          Set NAME to use for key files, e.g. bob.pub, bob.key. Defaults to valt.pub, valt.key."
    show "    -o, --output-dir PATH    Set output directory (default:" blue "${_valtConfigDir}" glue ")."
    echo "    -f, --force              Overwrite existing key files."
    echo "    --no-verify              Do not verify keys."
    echo "    --no-advice              Do not show passphrase advice."
    echo "    --no-pdf                 Do not generate PDF file."
    echo "    -k, --key-info PATH      Use the key info file at PATH instead of the default for PDF generation."
    echo "    -t, --template TEMPLATE  Use the TEMPLATE html file instead of the default for PDF generation."
    echo "    -c, --css CSS            Apply style overrides from the CSS file for PDF generation."
    commonOptions 29 false
    echo
    show bold "Document Customization"
    echo
    echo "The HTML template can be changed from the default and CSS style overrides can be applied. The default template"
    show "and primary CSS file can be found in the" blue "${valtHome}/etc" "directory."
    echo
    show "Template substitutions are performed with variables defined in the" blue "key.info" "file. Note that keys"
    echo "prefixed with an underscore are reserved for system use."
    echo
    echo "The template can be specified with the --template option, and default styles can be extended using the --css option."
    bye "${@}"
}

main() {
    init "${@}"
    createKeys
    if (( generatePdf )); then
        local paperKeyFile
        newPaperKey ${privateKeyFile} paperKeyFile "${keyInfoFile}" "${cssOverrideFile}"
    fi
}

init() {
    currentProjectName='valt' # force, since part of valt project
    local configDir; configDir="${ configDirPath; }"
    declare -gr _valtConfigDir="${configDir}"

    # Options
    declare -g outputDir; outputDir="${ configDirPath; }"
    declare -g keyInfoFile
    declare -g cssOverrideFile
    declare -g htmlFile
    declare -g keyName='-' # use default

    # Flags
    declare -g force=0
    declare -g verifyKeys=1
    declare -g generatePdf=1
    declare -gx skipKeyPassphraseAdvice=0

    while (( $# > 0 )); do
        case "$1" in
            --) ;;
            -n | --name) shift; setKeyName "$1" ;;
            -o | --output-dir) shift; setDirVar outputDir "$1" "output directory";;
            -k | --key-info) shift; setFileVar keyInfoFile "$1" "key info file path" ;;
            -t | --template) shift; setFileVar htmlTemplateFile "$1" "html template file path" ;;
            -c | --css) shift; setFileVar cssOverrideFile "$1" "CSS" ;;
            --no-verify) verifyKeys=0 ;;
            --no-advice) skipKeyPassphraseAdvice=1 ;;
            --no-pdf) generatePdf=0 ;;
            -q | --quick) skipKeyPassphraseAdvice=1; verifyKeys=0 ;;
            -f | --force) force=1 ;;
            -h | --help | help) usage ;;
            --debug*) setDebug "$@"; shift $? ;;
            -*) usage "Unknown option: $1" ;;
        esac
        shift
    done

    declare -g privateKeyFile="${outputDir}/${keyName}.key"
    declare -g publicKeyFile="${outputDir}/${keyName}.pub"

    if (( force )); then
        rm "${publicKeyFile}" "${privateKeyFile}" 2> /dev/null
    else
        assertFileDoesNotExist "${privateKeyFile}"
        assertFileDoesNotExist "${publicKeyFile}"
    fi
}

setKeyName() {
    assertValidFileName "$1"
    keyName="$1"
}

createKeys() {
    echo
    header -u "Generating Keys"

    newValtKeys "${keyName}" "${outputDir}" || fail
    local pubKeyFile; pubKeyFile="${ tildePath "${publicKeyFile}"; }"
    local keyFile; keyFile="${ tildePath "${privateKeyFile}"; }"
    echo
    show "Public key (aka 'recipient') file:" cyan "${pubKeyFile}"  "(includes public signing key)"
    show "Private key (aka 'identity') file:" cyan "${keyFile}" "(includes public key and both signing keys)"

    if (( verifyKeys )); then
        header 2 "Verifying keys"
        verifyValtKeys "${publicKeyFile}" "${privateKeyFile}"
        echo
        show bold "Verified" glue ":"
        echo
        show "  · A file encrypted with" cyan "${keyName}.pub" "decrypts with passphrase and the" cyan "${keyName}.key" "private key. ${successCheckMark}"
        show "  · A signature created with" cyan "${keyName}.key" "for the encrypted file matches. ${successCheckMark} "
    fi
}

source rayvn.up 'rayvn/prompt' 'rayvn/config' 'valt/keys' 'valt/paper-keys'

main "${@}"
